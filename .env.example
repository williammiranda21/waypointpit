# Supabase (Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Mapbox (mapbox.com → Account → Access Tokens)
VITE_MAPBOX_TOKEN=pk.your-mapbox-token-here

# AI proxy — set to the serverless endpoint to route Claude calls server-side.
# Leave UNSET for local dev (falls back to a localStorage key + browser-direct).
# In production (Vercel) set this so the API key never reaches the browser.
VITE_AI_PROXY=/api/insight

# Server-only — never expose in client bundles or VITE_ vars.
# Set these in the Vercel dashboard (Project → Settings → Environment Variables).
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_SERVICE_ROLE_KEY=...
